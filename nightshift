# --- Dependency checks ---

check_gh() {
    if ! command -v gh &>/dev/null; then
        echo "Error: GitHub CLI (gh) is not installed."
        echo "Install it: https://cli.github.com/"
        return 1
    fi
    if ! gh auth status &>/dev/null 2>&1; then
        echo "Error: GitHub CLI is not authenticated."
        echo "Run: gh auth login"
        return 1
    fi
    return 0
}

detect_ai_clis() {
    local found=""
    for cli in claude codex cursor; do
        if command -v "$cli" &>/dev/null; then
            found="${found:+$found }$cli"
        fi
    done
    echo "$found"
}

# --- AI CLI invocation ---

invoke_cli() {
    local cli="$1"
    local prompt_file="$2"
    local repo_dir="$3"

    local prompt_content
    prompt_content="$(cat "$prompt_file")"

    cd "$repo_dir"
    case "$cli" in
        claude)  claude -p "$prompt_content" 2>/dev/null ;;
        codex)   codex -q "$prompt_content" 2>/dev/null ;;
        cursor)  cursor -p "$prompt_content" 2>/dev/null ;;
        *)
            echo "Unknown CLI: $cli" >&2
            return 1
            ;;
    esac
}

# --- JSON extraction ---

extract_json() {
    local input="$1"
    if echo "$input" | jq . &>/dev/null 2>&1; then
        echo "$input"
        return 0
    fi
    local stripped
    stripped="$(echo "$input" | sed '/^```.*$/d')"
    if echo "$stripped" | jq . &>/dev/null 2>&1; then
        echo "$stripped"
        return 0
    fi
    return 1
}

# --- Config ---

read_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo "Error: Config not found at $CONFIG_FILE" >&2
        echo "Run: nightshift init" >&2
        return 1
    fi
    cat "$CONFIG_FILE"
}

get_config_value() {
    local key="$1"
    read_config | jq -r "$key" 2>/dev/null
}

get_repos_root() {
    local root
    root="$(get_config_value '.repos_root')" || return 1
    root="${root/#\~/$HOME}"
    echo "$root"
}

get_agent_cli() {
    local agent="$1"
    get_config_value ".agents.${agent}" 2>/dev/null || echo ""
}

# --- Per-repo config ---

is_agent_excluded() {
    local agent="$1"
    local repo_config="$2"
    echo "$repo_config" | jq -e ".exclude // [] | index(\"$agent\")" &>/dev/null
}

get_repo_agent_cli() {
    local agent="$1"
    local repo_config="$2"
    local override
    override="$(echo "$repo_config" | jq -r ".agents.${agent} // empty" 2>/dev/null)"
    if [[ -n "$override" ]]; then
        echo "$override"
    else
        get_agent_cli "$agent"
    fi
}

# --- Repo discovery ---

discover_repos() {
    local root="$1"
    for dir in "$root"/*/; do
        [[ -d "$dir/.git" ]] && echo "$(cd "$dir" && pwd)"
    done
}

# --- Git remote / provider detection ---

strip_remote_credentials() {
    local url="$1"
    if [[ "$url" =~ ^https?://[^/@]+@ ]]; then
        echo "$url" | sed -E 's#^(https?://)[^/@]+@#\1#'
    else
        echo "$url"
    fi
}

# Parses an Azure DevOps Git remote URL. On success prints JSON:
# {"org":"...","project":"...","repo":"..."} and returns 0.
# Supports modern HTTPS, legacy visualstudio.com HTTPS, SSH (v3), and PAT-embedded HTTPS
# (pass the URL after strip_remote_credentials).
parse_ado_remote() {
    local raw="$1"
    local url="${raw%/}"
    local org project repo

    shopt -s nocasematch

    if [[ "$url" =~ ^git@ssh\.dev\.azure\.com:v3/([^/]+)/([^/]+)/([^/]+)$ ]]; then
        org="${BASH_REMATCH[1]}"
        project="${BASH_REMATCH[2]}"
        repo="${BASH_REMATCH[3]}"
    elif [[ "$url" =~ ^https://dev\.azure\.com/([^/]+)/([^/]+)/_git/([^/]+)$ ]]; then
        org="${BASH_REMATCH[1]}"
        project="${BASH_REMATCH[2]}"
        repo="${BASH_REMATCH[3]}"
    elif [[ "$url" =~ ^https://([^.]+)\.visualstudio\.com/(.+)/_git/([^/]+)$ ]]; then
        org="${BASH_REMATCH[1]}"
        project="${BASH_REMATCH[2]}"
        repo="${BASH_REMATCH[3]}"
    else
        shopt -u nocasematch
        return 1
    fi

    shopt -u nocasematch

    repo="${repo%.git}"
    jq -cn --arg org "$org" --arg project "$project" --arg repo "$repo" \
        '{org: $org, project: $project, repo: $repo}'
}

# Reads git remote get-url origin for repo_dir. Prints github, azuredevops, or unknown.
# Optional repo_config JSON may override .provider (github|azuredevops|unknown only).
detect_provider() {
    local repo_dir="$1"
    local repo_config="${2-}"
    [[ -z "$repo_config" ]] && repo_config="{}"

    local remote_url normalized
    remote_url="$(git -C "$repo_dir" remote get-url origin 2>/dev/null || true)"
    normalized="$(strip_remote_credentials "$remote_url")"

    local detected="unknown"
    if [[ -n "$normalized" ]]; then
        if [[ "$normalized" == *"github.com"* ]]; then
            detected="github"
        elif parse_ado_remote "$normalized" &>/dev/null; then
            detected="azuredevops"
        fi
    fi

    local override
    override="$(echo "$repo_config" | jq -r '.provider // empty' 2>/dev/null || true)"
    if [[ -n "$override" ]] && [[ "$override" != "null" ]]; then
        case "$override" in
            github|azuredevops|unknown) detected="$override" ;;
        esac
    fi

    echo "$detected"
}

# ADO org/project/repo from origin URL merged with .nightshift.json ado_* overrides.
resolved_ado_metadata() {
    local repo_dir="$1"
    local repo_config="${2-}"
    [[ -z "$repo_config" ]] && repo_config="{}"

    local remote_url normalized parsed
    remote_url="$(git -C "$repo_dir" remote get-url origin 2>/dev/null || true)"
    normalized="$(strip_remote_credentials "$remote_url")"
    parsed="null"
    if p="$(parse_ado_remote "$normalized" 2>/dev/null)"; then
        parsed="$p"
    fi

    jq -n \
        --argjson parsed "$parsed" \
        --argjson cfg "$repo_config" \
        '
        (if $parsed == null then {"org": null, "project": null, "repo": null} else $parsed end)
        | .org = (
            if ($cfg.ado_org | type == "string") and ($cfg.ado_org | length) > 0
            then $cfg.ado_org else .org end)
        | .project = (
            if ($cfg.ado_project | type == "string") and ($cfg.ado_project | length) > 0
            then $cfg.ado_project else .project end)
        | .repo = (
            if ($cfg.ado_repo | type == "string") and ($cfg.ado_repo | length) > 0
            then $cfg.ado_repo else .repo end)
        '
}

# --- Azure DevOps REST (api-version=7.1) ---

# Ensures NIGHTSHIFT_ADO_PAT is set. Prints to stderr and returns 1 if missing.
require_ado_pat() {
    if [[ -z "${NIGHTSHIFT_ADO_PAT:-}" ]]; then
        echo "Error: NIGHTSHIFT_ADO_PAT is not set. Set this environment variable to an Azure DevOps personal access token (PAT) with access to the organization you use with nightshift." >&2
        return 1
    fi
    return 0
}

# Internal: GET request with Basic auth. Override NIGHTSHIFT_CURL in tests (must support curl CLI).
_nightshift_ado_curl() {
    "${NIGHTSHIFT_CURL:-curl}" "$@"
}

# ado_api_request <ado_root_url> <path>
# ado_root_url: e.g. https://dev.azure.com/myorg (no trailing slash)
# path: API path, optional query (e.g. _apis/projects?%24top=1)
# On success, prints the JSON body (validated) to stdout. On failure, prints a clear error to stderr.
ado_api_request() {
    if ! require_ado_pat; then
        return 1
    fi
    local base="${1-}" path="${2-}"
    if [[ -z "$base" ]] || [[ -z "$path" ]]; then
        echo "ado_api_request: usage: ado_api_request <ado_root_url> <path>" >&2
        return 1
    fi
    path="${path#/}"
    local apath
    if [[ "$path" == *"?"* ]]; then
        apath="${path}&api-version=7.1"
    else
        apath="${path}?api-version=7.1"
    fi
    local url="${base%/}/${apath}"

    local tmp
    tmp="$(mktemp)"
    local http_code
    if ! http_code="$(_nightshift_ado_curl -sS -o "$tmp" -w '%{http_code}' \
        -H "Accept: application/json" \
        -u ":$NIGHTSHIFT_ADO_PAT" \
        "$url")"; then
        rm -f "$tmp"
        echo "Error: Network request to Azure DevOps failed (connection or TLS error). Check your network and that the URL is correct: $url" >&2
        return 1
    fi

    local body
    body="$(cat "$tmp" 2>/dev/null || true)"
    rm -f "$tmp"

    if [[ "$http_code" =~ ^2[0-9][0-9]$ ]]; then
        if [[ -z "$body" ]]; then
            echo "Error: Azure DevOps returned an empty body (HTTP $http_code)." >&2
            return 1
        fi
        if ! echo "$body" | jq -e . &>/dev/null; then
            echo "Error: Azure DevOps returned a non-JSON response (HTTP $http_code). Body was not valid JSON." >&2
            return 1
        fi
        echo "$body" | jq .
        return 0
    fi

    local detail=""
    if [[ -n "$body" ]] && echo "$body" | jq -e . &>/dev/null; then
        detail="$(echo "$body" | jq -r '(.message // .value // .) | if type == "string" then . else tostring end' 2>/dev/null)" || detail=""
    fi
    if [[ -n "$detail" ]] && [[ "$detail" != "null" ]]; then
        detail=" $detail"
    else
        detail=""
    fi

    case "$http_code" in
        401)
            echo "Error: Azure DevOps rejected the personal access token (HTTP 401).${detail} — Verify that NIGHTSHIFT_ADO_PAT is correct, not expired, and has the required API scopes (e.g. code read) for the target organization." >&2
            ;;
        403)
            echo "Error: Access denied to Azure DevOps (HTTP 403).${detail} — The token may be valid but lacks permission for this resource, or a policy is blocking the request." >&2
            ;;
        404)
            echo "Error: Azure DevOps resource not found (HTTP 404).${detail} — Check the organization name, collection URL, and API path. If the organization or project was renamed or does not exist, the URL will not resolve." >&2
            ;;
        500|501|502|503|504)
            echo "Error: Azure DevOps service error (HTTP $http_code).${detail} — Try again later; the service or your organization may be temporarily unavailable." >&2
            ;;
        *)
            echo "Error: Azure DevOps request failed (HTTP $http_code).${detail} — $url" >&2
            ;;
    esac
    return 1
}

