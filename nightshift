#!/usr/bin/env bash
set -uo pipefail

VERSION="1.0.0"
NIGHTSHIFT_DIR="$HOME/.nightshift"
CONFIG_FILE="$NIGHTSHIFT_DIR/config.json"
LOG_DIR="$NIGHTSHIFT_DIR/logs"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -d "$HOME/.local/share/nightshift/prompts" ]]; then
    PROMPTS_DIR="$HOME/.local/share/nightshift/prompts"
elif [[ -d "$SCRIPT_DIR/prompts" ]]; then
    PROMPTS_DIR="$SCRIPT_DIR/prompts"
else
    PROMPTS_DIR=""
fi

ISSUES_CREATED=0
ISSUES_SKIPPED=0
ERRORS=0

ALL_AGENTS="bugs security architecture antipatterns dependencies documentation maintainability observability performance solidprinciples techdebt tests"

# --- Logging ---

log() {
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[$timestamp] $*"
}

# cmd_run: categorised error buckets (tab-separated "repo\tdetail" per line; detail may contain internal tabs)
RUN_ERR_AUTH_LINES=""
RUN_ERR_API_LINES=""
RUN_ERR_PARSE_LINES=""
RUN_ERR_CLI_LINES=""

record_run_error() {
    local kind="$1"
    local repo="$2"
    local detail="$3"
    local line
    line="${repo}"$'\t'"${detail}"
    case "$kind" in
        auth)  RUN_ERR_AUTH_LINES="${RUN_ERR_AUTH_LINES}${line}"$'\n' ;;
        api)   RUN_ERR_API_LINES="${RUN_ERR_API_LINES}${line}"$'\n' ;;
        parse) RUN_ERR_PARSE_LINES="${RUN_ERR_PARSE_LINES}${line}"$'\n' ;;
        cli)   RUN_ERR_CLI_LINES="${RUN_ERR_CLI_LINES}${line}"$'\n' ;;
    esac
}

# Read stderr from ADO fetch helpers; record auth or api.
record_run_error_from_ado_log() {
    local repo_name="$1"
    local err_file="${2-}"
    local text
    text="$(cat "$err_file" 2>/dev/null || true)"
    if echo "$text" | grep -qE "Failed to parse|not valid JSON|non-JSON response|empty body"; then
        local one
        one="$(echo "$text" | tr '\n' ' ' | sed 's/  */ /g')"
        one="${one:0:400}"
        record_run_error api "$repo_name" "$one"
        return
    fi
    if [[ -z "$text" ]]; then
        record_run_error api "$repo_name" "Missing or incomplete Azure DevOps metadata (organization, project, or repository)"
        return
    fi
    if echo "$text" | grep -q "NIGHTSHIFT_ADO_PAT is not set"; then
        record_run_error auth "$repo_name" "NIGHTSHIFT_ADO_PAT is not set (Azure DevOps)"
        return
    fi
    if echo "$text" | grep -qE "rejected the personal access token|HTTP 401|not authenticated"; then
        record_run_error auth "$repo_name" "Azure DevOps authentication failed (PAT invalid or expired; HTTP 401)"
        return
    fi
    local one
    one="$(echo "$text" | tr '\n' ' ' | sed 's/  */ /g')"
    one="${one:0:400}"
    [[ -z "$one" ]] && one="Azure DevOps API request failed"
    record_run_error api "$repo_name" "$one"
}

emit_run_error_summary() {
    if [[ -z "$RUN_ERR_AUTH_LINES" && -z "$RUN_ERR_API_LINES" && -z "$RUN_ERR_PARSE_LINES" && -z "$RUN_ERR_CLI_LINES" ]]; then
        return 0
    fi
    log "Error summary:"
    local section
    for section in "Auth errors|RUN_ERR_AUTH_LINES" "API errors|RUN_ERR_API_LINES" "Parse errors|RUN_ERR_PARSE_LINES" "CLI errors|RUN_ERR_CLI_LINES"; do
        local name="${section%%|*}"
        local varname="${section#*|}"
        local lines
        lines="${!varname}"
        if [[ -z "$lines" ]]; then
            continue
        fi
        log "  $name"
        while IFS= read -r eline; do
            [[ -z "$eline" ]] && continue
            local r d
            r="${eline%%$'\t'*}"
            d="${eline#*$'\t'}"
            log "    $r: $d"
        done <<< "$lines"
    done
}

