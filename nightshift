# create_ado_work_item <repo_dir> <repo_config_json> <agent> <title> <description_markdown>
# Creates a work item via JSON Patch. Title should include the [nightshift] prefix (same as GitHub issues).
# Returns 0 on success. Logs errors to stderr and returns non-zero on failure.
create_ado_work_item() {
    local repo_dir="$1"
    local repo_config="${2-}"
    local agent="${3-}"
    local title="${4-}"
    local description="${5-}"
    [[ -z "$repo_config" ]] && repo_config="{}"

    if ! require_ado_pat; then
        return 1
    fi

    local meta org project repo
    meta="$(resolved_ado_metadata "$repo_dir" "$repo_config")"
    org="$(echo "$meta" | jq -r '.org // empty')"
    project="$(echo "$meta" | jq -r '.project // empty')"
    repo="$(echo "$meta" | jq -r '.repo // empty')"

    if [[ -z "$org" ]] || [[ -z "$project" ]] || [[ -z "$repo" ]] || [[ "$org" == "null" ]]; then
        echo "Error: Cannot create Azure DevOps work item: missing organization, project, or repository (check git remote and .nightshift.json ado_* fields)." >&2
        return 1
    fi

    local wit_type global_default
    wit_type="$(echo "$repo_config" | jq -r '.ado_work_item_type // empty' 2>/dev/null)"
    global_default=""
    if [[ -f "$CONFIG_FILE" ]]; then
        global_default="$(jq -r '.ado_default_work_item_type // empty' "$CONFIG_FILE" 2>/dev/null)" || global_default=""
    fi
    if [[ -z "$wit_type" ]] || [[ "$wit_type" == "null" ]]; then
        wit_type="$global_default"
    fi
    if [[ -z "$wit_type" ]] || [[ "$wit_type" == "null" ]]; then
        wit_type="Product Backlog Item"
    fi

    local agent_label area_path iteration_path
    agent_label="$(get_label "$agent")"
    area_path="$(echo "$repo_config" | jq -r '.ado_area_path // empty' 2>/dev/null)"
    iteration_path="$(echo "$repo_config" | jq -r '.ado_iteration_path // empty' 2>/dev/null)"
    [[ "$area_path" == "null" ]] && area_path=""
    [[ "$iteration_path" == "null" ]] && iteration_path=""

    local tags="nightshift,${agent_label},nightshift-repo:${repo}"

    local ado_fields_json
    ado_fields_json="$(echo "$repo_config" | jq '.ado_fields // {}' 2>/dev/null)" || ado_fields_json="{}"

    local patch
    if ! patch="$(jq -n \
        --arg title "$title" \
        --arg desc "$description" \
        --arg tags "$tags" \
        --arg area "$area_path" \
        --arg iter "$iteration_path" \
        --argjson fields "$ado_fields_json" \
        '
        [
            {"op":"add","path":"/fields/System.Title","value":$title},
            {"op":"add","path":"/fields/System.Description","value":$desc},
            {"op":"add","path":"/fields/System.Tags","value":$tags}
        ]
        + (if ($area | length) > 0 then [{"op":"add","path":"/fields/System.AreaPath","value":$area}] else [] end)
        + (if ($iter | length) > 0 then [{"op":"add","path":"/fields/System.IterationPath","value":$iter}] else [] end)
        + ($fields | to_entries | map({op:"add", path: ("/fields/" + .key), value: .value}))
        ')"; then
        echo "Error: Failed to build Azure DevOps work item JSON Patch document." >&2
        return 1
    fi

    local base enc_project type_seg wi_path
    base="https://dev.azure.com/${org}"
    enc_project="$(jq -rn --arg p "$project" '$p|@uri')"
    type_seg="$(jq -rn --arg t "$wit_type" '"$" + ($t|@uri)')"
    wi_path="${enc_project}/_apis/wit/workitems/${type_seg}"

    if ! ado_api_json_patch_post_request "$base" "$wi_path" "$patch" >/dev/null; then
        return 1
    fi
    return 0
}

# _ado_fetch_work_item_titles <ado_base> <uri_encoded_project> <comma_separated_ids>
# Prints one title per line. Returns 1 if the API request fails.
_ado_fetch_work_item_titles() {
    local base="$1" enc_project="$2" ids_csv="$3"
    if [[ -z "$ids_csv" ]]; then
        return 0
    fi
    local wi_path items_json
    wi_path="${enc_project}/_apis/wit/workitems?ids=${ids_csv}&%24fields=System.Title"
    if ! items_json="$(ado_api_request "$base" "$wi_path")"; then
        return 1
    fi
    echo "$items_json" | jq -r '.value[]?.fields["System.Title"] // empty'
}

# _ado_work_items_abort_or_empty: in NIGHTSHIFT_ADO_STRICT mode, return 1; else print empty and return 0
_ado_work_items_abort_or_empty() {
    if [[ -n "${NIGHTSHIFT_ADO_STRICT:-}" ]]; then
        return 1
    fi
    echo ""
    return 0
}

# fetch_ado_work_items <repo_dir> [repo_config_json]
# Newline-separated titles of non-Closed, non-Done work items tagged nightshift and nightshift-repo:{repo}.
# Same shape as fetch_open_issues. On error or missing PAT/metadata, returns empty string (errors on stderr).
# When NIGHTSHIFT_ADO_STRICT is set (cmd_run), returns non-zero on those failures.
fetch_ado_work_items() {
    local repo_dir="$1"
    local repo_config="${2-}"
    [[ -z "$repo_config" ]] && repo_config="{}"

    if ! require_ado_pat; then
        _ado_work_items_abort_or_empty
        return
    fi

    local meta org project repo
    meta="$(resolved_ado_metadata "$repo_dir" "$repo_config")"
    org="$(echo "$meta" | jq -r '.org // empty')"
    project="$(echo "$meta" | jq -r '.project // empty')"
    repo="$(echo "$meta" | jq -r '.repo // empty')"

    if [[ -z "$org" ]] || [[ -z "$project" ]] || [[ -z "$repo" ]] || [[ "$org" == "null" ]]; then
        _ado_work_items_abort_or_empty
        return
    fi

    local repo_esc="$repo"
    repo_esc="${repo_esc//\'/\'\'}"

    local wiql
    wiql="SELECT [System.Title] FROM WorkItems WHERE [System.Tags] CONTAINS 'nightshift' AND [System.Tags] CONTAINS 'nightshift-repo:${repo_esc}' AND [System.State] <> 'Closed' AND [System.State] <> 'Done'"

    local query_json base enc_project wiql_path wiql_response
    query_json="$(jq -n --arg q "$wiql" '{query: $q}')"
    base="https://dev.azure.com/${org}"
    enc_project="$(jq -rn --arg p "$project" '$p|@uri')"
    wiql_path="${enc_project}/_apis/wit/wiql"

    if ! wiql_response="$(ado_api_post_request "$base" "$wiql_path" "$query_json")"; then
        _ado_work_items_abort_or_empty
        return
    fi

    local titles="" batch="" n=0 chunk_lines
    while IFS= read -r wid; do
        [[ -z "$wid" ]] && continue
        [[ -n "$batch" ]] && batch+=","
        batch+="$wid"
        n=$((n + 1))
        if [[ "$n" -eq 200 ]]; then
            if ! chunk_lines="$(_ado_fetch_work_item_titles "$base" "$enc_project" "$batch")"; then
                _ado_work_items_abort_or_empty
                return
            fi
            if [[ -n "$chunk_lines" ]]; then
                [[ -n "$titles" ]] && titles+=$'\n'
                titles+="$chunk_lines"
            fi
            batch=""
            n=0
        fi
    done < <(echo "$wiql_response" | jq -r '.workItems[]?.id // empty')

    if [[ -n "$batch" ]]; then
        if ! chunk_lines="$(_ado_fetch_work_item_titles "$base" "$enc_project" "$batch")"; then
            _ado_work_items_abort_or_empty
            return
        fi
        if [[ -n "$chunk_lines" ]]; then
            [[ -n "$titles" ]] && titles+=$'\n'
            titles+="$chunk_lines"
        fi
    fi

    printf '%s' "$titles"
    return 0
}

# In NIGHTSHIFT_ADO_STRICT mode, return 1; else print None and return 0
_ado_prs_abort_or_none() {
    if [[ -n "${NIGHTSHIFT_ADO_STRICT:-}" ]]; then
        return 1
    fi
    echo "None"
    return 0
}

# fetch_ado_prs <repo_dir> [repo_config_json]
# Active PRs via GET .../repositories/.../pullrequests?searchCriteria.status=active. Same text shape as fetch_open_prs
# (PR: title, body, ---). Prints "None" if there are no active PRs, on API error, or if metadata/PAT is missing.
# When NIGHTSHIFT_ADO_STRICT is set, returns non-zero on PAT/metadata/API failure (cmd_run only).
fetch_ado_prs() {
    local repo_dir="$1"
    local repo_config="${2-}"
    [[ -z "$repo_config" ]] && repo_config="{}"

    if ! require_ado_pat; then
        _ado_prs_abort_or_none
        return
    fi

    local meta org project reponame
    meta="$(resolved_ado_metadata "$repo_dir" "$repo_config")"
    org="$(echo "$meta" | jq -r '.org // empty')"
    project="$(echo "$meta" | jq -r '.project // empty')"
    reponame="$(echo "$meta" | jq -r '.repo // empty')"

    if [[ -z "$org" ]] || [[ -z "$project" ]] || [[ -z "$reponame" ]] || [[ "$org" == "null" ]]; then
        _ado_prs_abort_or_none
        return
    fi

    local base enc_project enc_repo pr_path pr_json
    base="https://dev.azure.com/${org}"
    enc_project="$(jq -rn --arg p "$project" '$p|@uri')"
    enc_repo="$(jq -rn --arg r "$reponame" '$r|@uri')"
    pr_path="${enc_project}/_apis/git/repositories/${enc_repo}/pullrequests?searchCriteria.status=active"

    if ! pr_json="$(ado_api_request "$base" "$pr_path")"; then
        _ado_prs_abort_or_none
        return
    fi

    local n
    n="$(echo "$pr_json" | jq -r '.value | length' 2>/dev/null)" || n="0"
    if ! [[ "$n" =~ ^[0-9]+$ ]]; then
        n="0"
    fi
    if [[ "$n" -eq 0 ]]; then
        echo "None"
        return 0
    fi

    local formatted
    if ! formatted="$(echo "$pr_json" | jq -r '.value[]? | "PR: \(.title)\n\(.description // "")\n---"' 2>/dev/null)"; then
        log "  Error: Failed to parse Azure DevOps pull request JSON"
        echo "Error: Failed to parse Azure DevOps pull request JSON" >&2
        if [[ -n "${NIGHTSHIFT_ADO_STRICT:-}" ]]; then
            return 1
        fi
        echo "None"
        return 0
    fi
    if [[ -z "$formatted" ]]; then
        echo "None"
    else
        printf '%s' "$formatted"
    fi
    return 0
}

# check_ado_auth <organization>
# Validates NIGHTSHIFT_ADO_PAT against GET .../_apis/projects?%24top=1 (dev.azure.com).
check_ado_auth() {
    local org="${1-}"
    if [[ -z "$org" ]]; then
        echo "check_ado_auth: organization name is required (e.g. the segment after https://dev.azure.com/)" >&2
        return 1
    fi
    if ! require_ado_pat; then
        return 1
    fi
    local base="https://dev.azure.com/${org}"
    if ! ado_api_request "$base" "_apis/projects?%24top=1" >/dev/null; then
        return 1
    fi
    echo "Azure DevOps authentication OK for organization '$org' (PAT accepted)."
    return 0
}

# ado_uri_encode_wit_type_segment <work_item_type_name>
# Path segment for .../workitemtypes/{segment}/fields (URI-encoded type name per REST docs).
ado_uri_encode_wit_type_segment() {
    local t="${1-}"
    jq -rn --arg wit "$t" '$wit|@uri'
}

# ado_wit_fields_response_to_required_prompt_json <json_body>
# JSON array of {referenceName, name} for alwaysRequired fields, excluding fields nightshift sets in the patch.
ado_wit_fields_response_to_required_prompt_json() {
    local body="${1-}"
    echo "$body" | jq '[.value[]?
        | select(.alwaysRequired == true)
        | select(.referenceName != "System.Title"
            and .referenceName != "System.Description"
            and .referenceName != "System.State"
            and .referenceName != "System.Tags")
        | {referenceName, name: (.name // .referenceName)}]'
}

# ado_fetch_wit_required_fields_json <org> <project> <work_item_type_name>
# Prints JSON array of {referenceName, name} on stdout, or empty array. Errors to stderr; returns non-zero on API failure.
ado_fetch_wit_required_fields_json() {
    local org="${1-}" project="${2-}" wit="${3-}"
    if [[ -z "$org" ]] || [[ -z "$project" ]] || [[ -z "$wit" ]]; then
        echo "ado_fetch_wit_required_fields_json: org, project, and work item type are required" >&2
        return 1
    fi
    local base enc_project type_seg path resp
    base="https://dev.azure.com/${org}"
    enc_project="$(jq -rn --arg p "$project" '$p|@uri')"
    type_seg="$(ado_uri_encode_wit_type_segment "$wit")"
    path="${enc_project}/_apis/wit/workitemtypes/${type_seg}/fields"
    if ! resp="$(ado_api_request "$base" "$path")"; then
        return 1
    fi
    ado_wit_fields_response_to_required_prompt_json "$resp"
}

# init_normalize_work_item_type_choice <user_input_or_empty>
# Maps PBI/Bug/Task (any case) or full names to canonical ADO type string.
init_normalize_work_item_type_choice() {
    local raw="${1-}"
    raw="$(echo "$raw" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    local lower
    lower="$(echo "$raw" | tr '[:upper:]' '[:lower:]')"
    case "$lower" in
        ""|pbi|"product backlog item")
            echo "Product Backlog Item"
            ;;
        bug)
            echo "Bug"
            ;;
        task)
            echo "Task"
            ;;
        *)
            echo "$raw"
            ;;
    esac
}

# init_ado_repo_fully_configured <repo_config_json> <required_fields_json_array> <work_item_type>
# Returns 0 if ado_work_item_type matches and ado_fields contains a non-empty string for each required referenceName.
init_ado_repo_fully_configured() {
    local cfg="${1-}" required_json="${2-}" wit="${3-}"
    local saved_type
    saved_type="$(echo "$cfg" | jq -r '.ado_work_item_type // empty' 2>/dev/null)" || saved_type=""
    if [[ -z "$saved_type" ]] || [[ "$saved_type" == "null" ]]; then
        return 1
    fi
    if [[ "$saved_type" != "$wit" ]]; then
        return 1
    fi
    if ! echo "$cfg" | jq -e '(.ado_fields | type) == "object"' &>/dev/null; then
        return 1
    fi
    if ! echo "$required_json" | jq -e --argjson c "$cfg" '
        all(.[]; .referenceName as $r
            | ($c.ado_fields[$r] // "") as $v
            | ($v | type == "string") and (($v | length) > 0))
    ' &>/dev/null; then
        return 1
    fi
    return 0
}

# --- Git operations ---

prepare_repo() {
    local repo_dir="$1"
    cd "$repo_dir"

    local default_branch
    default_branch="$(git remote show origin 2>/dev/null | awk '/HEAD branch/{print $NF}')" || default_branch=""
    if [[ -z "$default_branch" ]]; then
        default_branch="main"
    fi

    git checkout "$default_branch" --quiet 2>/dev/null || true
    git pull --quiet 2>/dev/null || true
}

# --- GitHub operations ---

fetch_open_issues() {
    local repo_dir="$1"
    cd "$repo_dir"
    gh issue list --state open --label nightshift --limit 500 --json title \
        2>/dev/null | jq -r '.[].title' 2>/dev/null || echo ""
}

fetch_open_prs() {
    local repo_dir="$1"
    cd "$repo_dir"
    gh pr list --state open --limit 50 --json title,body 2>/dev/null \
        | jq -r '.[] | "PR: \(.title)\n\(.body // "")\n---"' 2>/dev/null || echo "None"
}

# --- Provider dispatch (per-repo routing) ---

fetch_open_issues_for_repo() {
    local repo_dir="$1"
    local repo_config="${2-}"
    [[ -z "$repo_config" ]] && repo_config="{}"

    local provider
    provider="$(detect_provider "$repo_dir" "$repo_config")"
    if [[ "$provider" == "azuredevops" ]]; then
        fetch_ado_work_items "$repo_dir" "$repo_config"
    else
        fetch_open_issues "$repo_dir"
    fi
}

fetch_open_prs_for_repo() {
    local repo_dir="$1"
    local repo_config="${2-}"
    [[ -z "$repo_config" ]] && repo_config="{}"

    local provider
    provider="$(detect_provider "$repo_dir" "$repo_config")"
    if [[ "$provider" == "azuredevops" ]]; then
        fetch_ado_prs "$repo_dir" "$repo_config"
    else
        fetch_open_prs "$repo_dir"
    fi
}

create_work_item_for_repo() {
    local repo_dir="$1"
    local repo_config="${2-}"
    local agent="${3-}"
    local agent_label="${4-}"
    local title="${5-}"
    local body="${6-}"
    [[ -z "$repo_config" ]] && repo_config="{}"

    local provider
    provider="$(detect_provider "$repo_dir" "$repo_config")"
    if [[ "$provider" == "azuredevops" ]]; then
        create_ado_work_item "$repo_dir" "$repo_config" "$agent" "$title" "$body"
    else
        create_github_issue "$repo_dir" "$title" "$agent_label" "$body"
    fi
}

is_duplicate() {
    local title="$1"
    local existing_titles="$2"
    echo "$existing_titles" | grep -qFx "$title"
}

create_github_issue() {
    local repo_dir="$1"
    local title="$2"
    local agent_label="$3"
    local body="$4"

    cd "$repo_dir"
    gh issue create \
        --title "$title" \
        --label "nightshift,$agent_label" \
        --body "$body" 2>/dev/null
}

# --- Process findings ---

process_findings() {
    local repo_dir="$1"
    local agent="$2"
    local json_response="$3"
    local existing_titles="$4"
    local repo_config="${5-}"
    [[ -z "$repo_config" ]] && repo_config="{}"

    local json_key agent_label severity_field
    json_key="$(get_json_key "$agent")"
    agent_label="$(get_label "$agent")"
    severity_field="$(get_severity_field "$agent")"

    local count
    count="$(echo "$json_response" | jq -r ".${json_key} | length" 2>/dev/null)" || {
        log "  Error: Failed to parse JSON for $agent"
        record_run_error parse "$(basename "$repo_dir")" "Failed to parse JSON structure for $agent (jq)"
        ERRORS=$((ERRORS + 1))
        return 1
    }

    if [[ -z "$count" ]] || [[ "$count" == "null" ]] || [[ "$count" -eq 0 ]]; then
        return 0
    fi

    local created=0 skipped=0
    local i=0
    while [[ $i -lt $count ]]; do
        local item
        item="$(echo "$json_response" | jq ".${json_key}[$i]")"

        local raw_title
        raw_title="$(echo "$item" | jq -r '.title')"
        local title="[nightshift] $raw_title"

        local in_progress
        in_progress="$(echo "$item" | jq -r '.already_in_progress // false')"
        if [[ "$in_progress" == "true" ]]; then
            skipped=$((skipped + 1))
            ISSUES_SKIPPED=$((ISSUES_SKIPPED + 1))
            i=$((i + 1))
            continue
        fi

        if is_duplicate "$title" "$existing_titles"; then
            skipped=$((skipped + 1))
            ISSUES_SKIPPED=$((ISSUES_SKIPPED + 1))
            i=$((i + 1))
            continue
        fi

        local severity file line_hint description
        severity="$(echo "$item" | jq -r "(.${severity_field} // .severity // .priority // \"medium\")")"
        file="$(echo "$item" | jq -r '(.file // .manifest_file // "N/A")')"
        line_hint="$(echo "$item" | jq -r '.line_hint // empty' 2>/dev/null)" || line_hint=""
        description="$(echo "$item" | jq -r '.description')"

        local file_display
        if [[ -n "$line_hint" ]] && [[ "$line_hint" != "null" ]]; then
            file_display="\`${file}\` (line ${line_hint})"
        else
            file_display="\`${file}\`"
        fi

        local body
        body="> 🌙 Raised by nightshift on $(date '+%Y-%m-%d')

**Severity:** ${severity}
**File:** ${file_display}

${description}"

        local created_ok=false
        if create_work_item_for_repo "$repo_dir" "$repo_config" "$agent" "$agent_label" "$title" "$body"; then
            created_ok=true
        fi
        if [[ "$created_ok" == "true" ]]; then
            created=$((created + 1))
            ISSUES_CREATED=$((ISSUES_CREATED + 1))
        else
            ERRORS=$((ERRORS + 1))
            if [[ "$(detect_provider "$repo_dir" "$repo_config")" == "azuredevops" ]]; then
                record_run_error api "$(basename "$repo_dir")" "Failed to create Azure DevOps work item"
            fi
        fi

        i=$((i + 1))
    done

    log "  $agent → $created issues created, $skipped skipped (duplicate/in-progress)"
}

# --- cmd: run ---

repo_in_skip_list() {
    local path="$1"
    local list="${2-}"
    local line
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        [[ "$line" == "$path" ]] && return 0
    done <<< "$list"
    return 1
}

cmd_run() {
    log "Starting nightshift run"

    RUN_ERR_AUTH_LINES=""
    RUN_ERR_API_LINES=""
    RUN_ERR_PARSE_LINES=""
    RUN_ERR_CLI_LINES=""

    if [[ -z "$PROMPTS_DIR" ]] || [[ ! -d "$PROMPTS_DIR" ]]; then
        log "Error: Prompts directory not found"
        exit 1
    fi

    local repos_root
    repos_root="$(get_repos_root)" || exit 1

    local repos repo_count
    repos="$(discover_repos "$repos_root")"
    repo_count="$(echo "$repos" | grep -c . 2>/dev/null || echo 0)"

    local need_github=false
    local ado_repos_qualified=""
    local skip_repos=""
    local repo_dir_scan
    while IFS= read -r repo_dir_scan; do
        [[ -z "$repo_dir_scan" ]] && continue
        local scan_config="{}"
        if [[ -f "$repo_dir_scan/.nightshift.json" ]]; then
            scan_config="$(cat "$repo_dir_scan/.nightshift.json")"
        fi
        local scan_provider
        scan_provider="$(detect_provider "$repo_dir_scan" "$scan_config")"
        if [[ "$scan_provider" == "azuredevops" ]]; then
            local scan_org
            scan_org="$(resolved_ado_metadata "$repo_dir_scan" "$scan_config" | jq -r '.org // empty')"
            if [[ -z "$scan_org" ]] || [[ "$scan_org" == "null" ]]; then
                log "Error: Azure DevOps provider for $(basename "$repo_dir_scan") but organization could not be resolved (check git remote and .nightshift.json ado_org)."
                record_run_error auth "$(basename "$repo_dir_scan")" "Organization could not be resolved (check git remote and .nightshift.json ado_org)"
                skip_repos="${skip_repos}${repo_dir_scan}"$'\n'
                ERRORS=$((ERRORS + 1))
            else
                ado_repos_qualified="${ado_repos_qualified}${repo_dir_scan}|${scan_org}"$'\n'
            fi
        else
            need_github=true
        fi
    done <<< "$repos"

    if [[ "$need_github" == true ]]; then
        if ! check_gh; then
            exit 1
        fi
    fi

    if [[ -n "$ado_repos_qualified" ]]; then
        if ! require_ado_pat; then
            while IFS='|' read -r path_ado o_ado; do
                [[ -z "$path_ado" ]] && continue
                log "Error: NIGHTSHIFT_ADO_PAT is not set; skipping $(basename "$path_ado")"
                record_run_error auth "$(basename "$path_ado")" "NIGHTSHIFT_ADO_PAT is not set (Azure DevOps)"
                skip_repos="${skip_repos}${path_ado}"$'\n'
                ERRORS=$((ERRORS + 1))
            done <<< "$ado_repos_qualified"
        else
            local uorg
            uorg="$(printf '%s' "$ado_repos_qualified" | cut -d'|' -f2 | sort -u)"
            while IFS= read -r ado_org; do
                [[ -z "$ado_org" ]] && continue
                if ! check_ado_auth "$ado_org" &>/dev/null; then
                    while IFS='|' read -r path2 org2; do
                        [[ -z "$path2" ]] && continue
                        if [[ "$org2" == "$ado_org" ]]; then
                            if repo_in_skip_list "$path2" "$skip_repos"; then
                                continue
                            fi
                            log "Error: Azure DevOps authentication failed for $(basename "$path2") (organization: $ado_org)"
                            record_run_error auth "$(basename "$path2")" "Azure DevOps authentication failed for organization '$ado_org'"
                            skip_repos="${skip_repos}${path2}"$'\n'
                            ERRORS=$((ERRORS + 1))
                        fi
                    done <<< "$ado_repos_qualified"
                fi
            done <<< "$uorg"
        fi
    fi

    log "Scanning $repo_count repos in $repos_root"

    export NIGHTSHIFT_ADO_STRICT=1
    local repo_dir
    while IFS= read -r repo_dir; do
        [[ -z "$repo_dir" ]] && continue
        local repo_name
        repo_name="$(basename "$repo_dir")"

        if repo_in_skip_list "$repo_dir" "$skip_repos"; then
            log "Skipping $repo_name (Azure DevOps preflight error)"
            continue
        fi

        prepare_repo "$repo_dir"

        local repo_config="{}"
        if [[ -f "$repo_dir/.nightshift.json" ]]; then
            repo_config="$(cat "$repo_dir/.nightshift.json")"
        fi

        local prov
        prov="$(detect_provider "$repo_dir" "$repo_config")"
        local existing_titles open_prs
        if [[ "$prov" == "azuredevops" ]]; then
            local errf
            errf="$(mktemp)"
            if ! existing_titles="$(fetch_open_issues_for_repo "$repo_dir" "$repo_config" 2>"$errf")"; then
                log "  Error: could not load open work items from Azure DevOps; skipping $repo_name"
                record_run_error_from_ado_log "$repo_name" "$errf"
                rm -f "$errf"
                ERRORS=$((ERRORS + 1))
                continue
            fi
            rm -f "$errf"
            errf="$(mktemp)"
            if ! open_prs="$(fetch_open_prs_for_repo "$repo_dir" "$repo_config" 2>"$errf")"; then
                log "  Error: could not load open pull requests from Azure DevOps; skipping $repo_name"
                record_run_error_from_ado_log "$repo_name" "$errf"
                rm -f "$errf"
                ERRORS=$((ERRORS + 1))
                continue
            fi
            rm -f "$errf"
        else
            existing_titles="$(fetch_open_issues_for_repo "$repo_dir" "$repo_config")"
            open_prs="$(fetch_open_prs_for_repo "$repo_dir" "$repo_config")"
        fi

        local agent
        for agent in $ALL_AGENTS; do
            if is_agent_excluded "$agent" "$repo_config"; then
                continue
            fi

            local cli
            cli="$(get_repo_agent_cli "$agent" "$repo_config")"
            if [[ -z "$cli" ]] || [[ "$cli" == "null" ]]; then
                continue
            fi

            local prompt_file="$PROMPTS_DIR/${agent}.md"
            if [[ ! -f "$prompt_file" ]]; then
                log "  Warning: Prompt not found: $prompt_file"
                continue
            fi

            log "$repo_name: running $agent agent ($cli)"

            local prompt_content
            prompt_content="$(cat "$prompt_file")"
            prompt_content="${prompt_content//\$\{open_pr_summary\}/$open_prs}"

            local tmp_prompt
            tmp_prompt="$(mktemp)"
            printf '%s' "$prompt_content" > "$tmp_prompt"

            local response
            if response="$(invoke_cli "$cli" "$tmp_prompt" "$repo_dir" 2>&1)"; then
                local json_response
                if json_response="$(extract_json "$response")"; then
                    process_findings "$repo_dir" "$agent" "$json_response" "$existing_titles" "$repo_config"
                else
                    log "  Error: Invalid JSON from $agent agent"
                    record_run_error parse "$repo_name" "Invalid JSON from $agent agent output ($cli)"
                    ERRORS=$((ERRORS + 1))
                fi
            else
                log "  Error: $agent agent ($cli) failed"
                record_run_error cli "$repo_name" "$agent agent ($cli) failed"
                ERRORS=$((ERRORS + 1))
            fi

            rm -f "$tmp_prompt"
        done
    done <<< "$repos"
    unset NIGHTSHIFT_ADO_STRICT

    log "Run complete — $ISSUES_CREATED issues created, $ISSUES_SKIPPED skipped (duplicate), $ERRORS error(s)"
    emit_run_error_summary
}

# --- cmd: init ---

# init_prompt_append_gitignore <repo_directory>
init_prompt_append_gitignore() {
    local repo_dir="${1-}"
    local gi="$repo_dir/.gitignore"
    if [[ -f "$gi" ]] && grep -qE '^[[:space:]]*\.nightshift\.json[[:space:]]*$' "$gi" 2>/dev/null; then
        return 0
    fi
    local ans
    read -r -p "Add .nightshift.json to .gitignore in $(basename "$repo_dir")? [y/N]: " ans || true
    if [[ "$ans" == "y" ]] || [[ "$ans" == "Y" ]]; then
        printf '\n# nightshift local config\n.nightshift.json\n' >> "$gi"
        echo "  Appended .nightshift.json to $gi"
    fi
}

# cmd_init_process_ado_repos <repos_root_expanded> <global_wit_full> <reuse_state_file>
cmd_init_process_ado_repos() {
    local repos_root_expanded="${1-}" global_wit_full="${2-}" reuse_state="${3-}"
    local repos repo_dir
    repos="$(discover_repos "$repos_root_expanded")"

    echo "Configuring Azure DevOps repositories (.nightshift.json)..."
    while IFS= read -r repo_dir; do
        [[ -z "$repo_dir" ]] && continue
        local repo_name pc pv
        repo_name="$(basename "$repo_dir")"
        pc="{}"
        if [[ -f "$repo_dir/.nightshift.json" ]]; then
            pc="$(cat "$repo_dir/.nightshift.json")"
        fi
        pv="$(detect_provider "$repo_dir" "$pc")"
        if [[ "$pv" != "azuredevops" ]]; then
            continue
        fi

        local meta org project reponame
        meta="$(resolved_ado_metadata "$repo_dir" "$pc")"
        org="$(echo "$meta" | jq -r '.org // empty')"
        project="$(echo "$meta" | jq -r '.project // empty')"
        reponame="$(echo "$meta" | jq -r '.repo // empty')"
        if [[ -z "$org" ]] || [[ "$org" == "null" ]] || [[ -z "$project" ]] || [[ "$project" == "null" ]]; then
            echo "  $repo_name: skip ADO config (could not resolve organization/project from remote or .nightshift.json)"
            continue
        fi

        local wit wit_in saved_type
        saved_type="$(echo "$pc" | jq -r '.ado_work_item_type // empty' 2>/dev/null)" || saved_type=""
        if [[ -n "$saved_type" ]] && [[ "$saved_type" != "null" ]]; then
            wit="$saved_type"
            echo "  $repo_name: work item type (saved): $wit"
        else
            read -r -p "  Work item type for $repo_name — PBI, Bug, or Task [$(init_wit_to_short_label "$global_wit_full")]: " wit_in || wit_in=""
            wit="$(init_normalize_work_item_type_choice "${wit_in:-$global_wit_full}")"
        fi

        local required_json
        if ! required_json="$(ado_fetch_wit_required_fields_json "$org" "$project" "$wit")"; then
            echo "  $repo_name: could not load required fields from Azure DevOps (check type name and permissions); skipping"
            continue
        fi

        if init_ado_repo_fully_configured "$pc" "$required_json" "$wit"; then
            echo "  $repo_name: ADO settings already present; no changes"
            local subset_fields
            subset_fields="$(echo "$pc" | jq --argjson req "$required_json" '
                ($req | map(.referenceName)) as $keys
                | (.ado_fields // {})
                | with_entries(select(.key as $k | $keys | index($k) != null))
            ')"
            printf '%s\t%s\n' "${org}|${project}|${wit}" "$(echo "$subset_fields" | jq -c .)" >> "$reuse_state"
            continue
        fi

        local cache_key reuse_line reuse_json ans_r
        cache_key="${org}|${project}|${wit}"
        reuse_json="{}"
        if [[ -s "$reuse_state" ]]; then
            reuse_line="$(awk -F'	' -v k="$cache_key" '$1 == k { print $2; exit }' "$reuse_state")"
            if [[ -n "$reuse_line" ]]; then
                reuse_json="$reuse_line"
                read -r -p "  Reuse required field defaults from another repo in ${project} (${wit})? [Y/n]: " ans_r || ans_r=""
                if [[ -n "$ans_r" ]] && [[ "$ans_r" != "y" ]] && [[ "$ans_r" != "Y" ]]; then
                    reuse_json="{}"
                fi
            fi
        fi

        local existing_fields
        existing_fields="$(echo "$pc" | jq '.ado_fields // {}' 2>/dev/null)" || existing_fields="{}"

        local final_fields
        final_fields="$existing_fields"
        local idx ref fname val cur prompt_val
        idx=0
        local nreq
        nreq="$(echo "$required_json" | jq 'length' 2>/dev/null)" || nreq="0"
        while [[ "$idx" -lt "$nreq" ]]; do
            ref="$(echo "$required_json" | jq -r ".[$idx].referenceName")"
            fname="$(echo "$required_json" | jq -r ".[$idx].name")"
            cur="$(echo "$final_fields" | jq -r --arg r "$ref" '.[$r] // empty')"
            prompt_val=""
            if [[ -n "$cur" ]] && [[ "$cur" != "null" ]]; then
                idx=$((idx + 1))
                continue
            fi
            if [[ -n "$reuse_json" ]]; then
                prompt_val="$(echo "$reuse_json" | jq -r --arg r "$ref" '.[$r] // empty' 2>/dev/null)" || prompt_val=""
            fi
            if [[ -z "$prompt_val" ]] || [[ "$prompt_val" == "null" ]]; then
                read -r -p "    ${fname} (${ref}) [required]: " val || val=""
                prompt_val="$val"
            fi
            if [[ -n "$prompt_val" ]]; then
                final_fields="$(echo "$final_fields" | jq --arg r "$ref" --arg v "$prompt_val" '. + {($r): $v}')"
            fi
            idx=$((idx + 1))
        done

        local cfg_out cfg_before
        cfg_before="$(echo "$pc" | jq -c . 2>/dev/null)" || cfg_before="{}"
        cfg_out="$(echo "$pc" | jq --arg wit "$wit" --argjson fields "$final_fields" \
            '.ado_work_item_type = $wit | .ado_fields = $fields')"

        if [[ "$cfg_before" == "$(echo "$cfg_out" | jq -c .)" ]]; then
            echo "  $repo_name: no updates needed"
            continue
        fi

        printf '%s\n' "$cfg_out" > "$repo_dir/.nightshift.json"
        echo "  $repo_name: wrote .nightshift.json"

        printf '%s\t%s\n' "$cache_key" "$(echo "$final_fields" | jq -c .)" >> "$reuse_state"

        init_prompt_append_gitignore "$repo_dir"
    done <<< "$repos"
    echo ""
}

init_wit_to_short_label() {
    case "${1-}" in
        "Product Backlog Item") echo "PBI" ;;
        Bug)                    echo "Bug" ;;
        Task)                   echo "Task" ;;
        *)                      echo "${1:-PBI}" ;;
    esac
}

cmd_init() {
    echo "nightshift setup"
    echo ""

    echo "Detecting AI CLIs..."
    local available_clis
    available_clis="$(detect_ai_clis)"

    if [[ -z "$available_clis" ]]; then
        echo "Error: No supported AI CLI found."
        echo "Install one of: claude, codex, cursor"
        exit 1
    fi

    for cli in $available_clis; do
        echo "  found: $cli"
    done
    echo ""

    local repos_root
    read -r -p "Repos root directory [~/Developer]: " repos_root
    repos_root="${repos_root:-~/Developer}"
    local repos_root_expanded="${repos_root/#\~/$HOME}"

    if [[ ! -d "$repos_root_expanded" ]]; then
        echo "Error: Directory not found: $repos_root_expanded"
        exit 1
    fi
    echo ""

    local repos_preview need_github has_ado repo_line pc pv
    repos_preview="$(discover_repos "$repos_root_expanded")"
    need_github=false
    has_ado=false
    while IFS= read -r repo_line; do
        [[ -z "$repo_line" ]] && continue
        pc="{}"
        if [[ -f "$repo_line/.nightshift.json" ]]; then
            pc="$(cat "$repo_line/.nightshift.json")"
        fi
        pv="$(detect_provider "$repo_line" "$pc")"
        if [[ "$pv" == "azuredevops" ]]; then
            has_ado=true
        else
            need_github=true
        fi
    done <<< "$repos_preview"

    if [[ "$need_github" == true ]]; then
        echo "Checking GitHub CLI..."
        if ! check_gh; then
            exit 1
        fi
        echo "  gh is installed and authenticated"
        echo ""
    else
        echo "No GitHub remotes detected under repos root; skipping GitHub CLI check."
        echo ""
    fi

    local ado_default_wit_full wit_prompt_default prev_wit
    ado_default_wit_full="Product Backlog Item"
    wit_prompt_default="PBI"
    if [[ "$has_ado" == true ]]; then
        if ! require_ado_pat; then
            exit 1
        fi
        local org_lines uorg org
        org_lines=""
        while IFS= read -r repo_line; do
            [[ -z "$repo_line" ]] && continue
            pc="{}"
            if [[ -f "$repo_line/.nightshift.json" ]]; then
                pc="$(cat "$repo_line/.nightshift.json")"
            fi
            if [[ "$(detect_provider "$repo_line" "$pc")" != "azuredevops" ]]; then
                continue
            fi
            org="$(resolved_ado_metadata "$repo_line" "$pc" | jq -r '.org // empty')"
            if [[ -n "$org" ]] && [[ "$org" != "null" ]]; then
                org_lines="${org_lines}${org}"$'\n'
            fi
        done <<< "$repos_preview"
        uorg="$(printf '%s' "$org_lines" | sort -u | sed '/^$/d')"
        while IFS= read -r org; do
            [[ -z "$org" ]] && continue
            if ! check_ado_auth "$org"; then
                echo "Error: Azure DevOps PAT validation failed for organization '$org'."
                echo "Set NIGHTSHIFT_ADO_PAT and ensure it can read work items, then run init again."
                exit 1
            fi
        done <<< "$uorg"

        if [[ -f "$CONFIG_FILE" ]]; then
            prev_wit="$(jq -r '.ado_default_work_item_type // empty' "$CONFIG_FILE" 2>/dev/null)" || prev_wit=""
            if [[ -n "$prev_wit" ]] && [[ "$prev_wit" != "null" ]]; then
                ado_default_wit_full="$prev_wit"
                wit_prompt_default="$(init_wit_to_short_label "$prev_wit")"
            fi
        fi

        local wit_g_in
        echo "Azure DevOps: choose the default work item type for new repos (you can override per repo)."
        read -r -p "Default work item type (PBI, Bug, Task) [$wit_prompt_default]: " wit_g_in || wit_g_in=""
        if [[ -n "$wit_g_in" ]]; then
            ado_default_wit_full="$(init_normalize_work_item_type_choice "$wit_g_in")"
        else
            ado_default_wit_full="$(init_normalize_work_item_type_choice "$wit_prompt_default")"
        fi
        echo ""
    fi

    local run_hour
    read -r -p "Run time (hour, 0-23) [2]: " run_hour
    run_hour="${run_hour:-2}"
    local schedule="0 $run_hour * * *"
    echo ""

    echo "Assign an AI CLI to each agent."
    echo "Available: $available_clis"
    echo "Press Enter for default, or type 'skip' to disable."
    echo ""

    local default_cli
    default_cli="$(echo "$available_clis" | awk '{print $1}')"

    local agents_json="{"
    local first=true
    for agent in $ALL_AGENTS; do
        local chosen
        read -r -p "  $agent [$default_cli]: " chosen
        chosen="${chosen:-$default_cli}"

        if [[ "$chosen" == "skip" ]]; then
            continue
        fi

        if ! echo " $available_clis " | grep -q " $chosen "; then
            echo "    '$chosen' not detected, using $default_cli"
            chosen="$default_cli"
        fi

        if [[ "$first" == "true" ]]; then
            first=false
        else
            agents_json="${agents_json},"
        fi
        agents_json="${agents_json}\"${agent}\":\"${chosen}\""
    done
    agents_json="${agents_json}}"
    echo ""

    mkdir -p "$NIGHTSHIFT_DIR"
    local config
    if [[ "$has_ado" == true ]]; then
        config="$(jq -n \
            --arg repos_root "$repos_root" \
            --arg schedule "$schedule" \
            --argjson agents "$agents_json" \
            --arg ado_wit "$ado_default_wit_full" \
            '{repos_root: $repos_root, schedule: $schedule, agents: $agents, ado_default_work_item_type: $ado_wit}')"
    else
        config="$(jq -n \
            --arg repos_root "$repos_root" \
            --arg schedule "$schedule" \
            --argjson agents "$agents_json" \
            '{repos_root: $repos_root, schedule: $schedule, agents: $agents}')"
    fi

    echo "$config" > "$CONFIG_FILE"
    echo "Config written to $CONFIG_FILE"
    echo ""

    if [[ "$need_github" == true ]]; then
        echo "Creating labels in GitHub repositories..."
        local repos repo_dir
        repos="$(discover_repos "$repos_root_expanded")"

        while IFS= read -r repo_dir; do
            [[ -z "$repo_dir" ]] && continue
            local repo_name rcfg prov
            repo_name="$(basename "$repo_dir")"
            rcfg="{}"
            if [[ -f "$repo_dir/.nightshift.json" ]]; then
                rcfg="$(cat "$repo_dir/.nightshift.json")"
            fi
            prov="$(detect_provider "$repo_dir" "$rcfg")"
            if [[ "$prov" == "azuredevops" ]]; then
                continue
            fi

            echo "  $repo_name"

            cd "$repo_dir"
            gh label create "nightshift" --description "Raised by nightshift" --color "1d1d8a" --force 2>/dev/null || true

            local agent
            for agent in $ALL_AGENTS; do
                local label
                label="$(get_label "$agent")"
                gh label create "$label" --force 2>/dev/null || true
            done
        done <<< "$repos"
        echo ""
    fi

    if [[ "$has_ado" == true ]]; then
        local ado_reuse_state
        ado_reuse_state="$(mktemp)"
        cmd_init_process_ado_repos "$repos_root_expanded" "$ado_default_wit_full" "$ado_reuse_state"
        rm -f "$ado_reuse_state"
    fi

    register_cron "$schedule"

    echo ""
    echo "nightshift is ready. Next run: $(describe_schedule "$schedule")"
}

# --- Cron ---

register_cron() {
    local schedule="$1"
    local nightshift_bin
    nightshift_bin="$(command -v nightshift 2>/dev/null || echo "$SCRIPT_DIR/nightshift")"

    local cron_line="$schedule $nightshift_bin run >> $LOG_DIR/\$(date +\\%Y-\\%m-\\%d).log 2>&1"

    local existing filtered
    existing="$(crontab -l 2>/dev/null)" || existing=""
    filtered="$(echo "$existing" | grep -v "nightshift run")" || filtered=""

    mkdir -p "$LOG_DIR"

    if [[ -n "$filtered" ]]; then
        printf '%s\n%s\n' "$filtered" "$cron_line" | crontab -
    else
        echo "$cron_line" | crontab -
    fi

    echo "Cron registered: $cron_line"
}

describe_schedule() {
    local schedule="$1"
    local hour
    hour="$(echo "$schedule" | awk '{print $2}')"
    printf 'daily at %02d:00\n' "$hour"
}

get_cron_schedule() {
    crontab -l 2>/dev/null | grep "nightshift run" | awk '{print $1, $2, $3, $4, $5}' || echo ""
}

# --- cmd: logs ---

cmd_logs() {
    local date_arg="${1:-}"

    mkdir -p "$LOG_DIR"

    if [[ -n "$date_arg" ]]; then
        local log_file="$LOG_DIR/${date_arg}.log"
        if [[ -f "$log_file" ]]; then
            cat "$log_file"
        else
            echo "No log found for $date_arg"
            exit 1
        fi
    else
        local latest
        latest="$(ls -t "$LOG_DIR"/*.log 2>/dev/null | head -1)" || latest=""
        if [[ -z "$latest" ]]; then
            echo "No logs found in $LOG_DIR"
            exit 1
        fi
        cat "$latest"
    fi
}

# --- cmd: status ---

cmd_status() {
    echo "nightshift status"
    echo ""

    if [[ -f "$CONFIG_FILE" ]]; then
        echo "Config: $CONFIG_FILE"
        local repos_root
        repos_root="$(get_repos_root)" || repos_root="(error reading config)"

        echo "Repos root: $repos_root"

        if [[ -d "$repos_root" ]]; then
            local repo_count
            repo_count="$(discover_repos "$repos_root" | grep -c . 2>/dev/null || echo 0)"
            echo "Repos discovered: $repo_count"

            local repo_dir rcfg provider ado_line
            while IFS= read -r repo_dir; do
                [[ -z "$repo_dir" ]] && continue
                rcfg="{}"
                if [[ -f "$repo_dir/.nightshift.json" ]]; then
                    rcfg="$(cat "$repo_dir/.nightshift.json")"
                fi
                provider="$(detect_provider "$repo_dir" "$rcfg")"
                ado_line=""
                if [[ "$provider" == "azuredevops" ]]; then
                    ado_line="$(resolved_ado_metadata "$repo_dir" "$rcfg" | jq -r '
                        if (.org | type == "string") and (.project | type == "string") and (.repo | type == "string")
                        then " (" + .org + "/" + .project + "/" + .repo + ")"
                        else "" end' 2>/dev/null || true)"
                fi
                echo "  $(basename "$repo_dir"): $provider${ado_line}"
            done <<< "$(discover_repos "$repos_root")"
        fi
        echo ""

        echo "Agent assignments:"
        for agent in $ALL_AGENTS; do
            local cli
            cli="$(get_agent_cli "$agent")"
            if [[ -n "$cli" ]] && [[ "$cli" != "null" ]]; then
                echo "  $agent -> $cli"
            else
                echo "  $agent -> (disabled)"
            fi
        done
    else
        echo "Config: not found (run 'nightshift init')"
    fi
    echo ""

    echo "AI CLIs:"
    for cli in claude codex cursor; do
        if command -v "$cli" &>/dev/null; then
            echo "  [ok] $cli"
        else
            echo "  [--] $cli (not found)"
        fi
    done
    echo ""

    echo "GitHub CLI:"
    if command -v gh &>/dev/null; then
        if gh auth status &>/dev/null 2>&1; then
            echo "  [ok] gh (authenticated)"
        else
            echo "  [--] gh (not authenticated)"
        fi
    else
        echo "  [--] gh (not installed)"
    fi
    echo ""

    echo "Azure DevOps:"
    if [[ -z "${NIGHTSHIFT_ADO_PAT:-}" ]]; then
        echo "  [--] PAT (not set)"
    else
        local status_rr ado_cnt ado_org_lines uorg pat_all_ok _rd _cfg _pv _org
        status_rr=""
        ado_cnt=0
        ado_org_lines=""
        if [[ -f "$CONFIG_FILE" ]]; then
            status_rr="$(get_repos_root 2>/dev/null)" || status_rr=""
            if [[ -n "$status_rr" ]] && [[ -d "$status_rr" ]]; then
                while IFS= read -r _rd; do
                    [[ -z "$_rd" ]] && continue
                    _cfg="{}"
                    if [[ -f "$_rd/.nightshift.json" ]]; then
                        _cfg="$(cat "$_rd/.nightshift.json")"
                    fi
                    _pv="$(detect_provider "$_rd" "$_cfg")"
                    if [[ "$_pv" == "azuredevops" ]]; then
                        ado_cnt=$((ado_cnt + 1))
                        _org="$(resolved_ado_metadata "$_rd" "$_cfg" | jq -r '.org // empty')"
                        if [[ -n "$_org" ]] && [[ "$_org" != "null" ]]; then
                            ado_org_lines="${ado_org_lines}${_org}"$'\n'
                        fi
                    fi
                done <<< "$(discover_repos "$status_rr")"
            fi
        fi

        uorg=""
        if [[ -n "$ado_org_lines" ]]; then
            uorg="$(printf '%s' "$ado_org_lines" | sort -u | sed '/^$/d')"
        fi

        if [[ "$ado_cnt" -eq 0 ]]; then
            echo "  [ok] PAT (set)"
        elif [[ -z "$uorg" ]]; then
            echo "  [--] PAT (invalid)"
        else
            pat_all_ok=true
            while IFS= read -r _org; do
                [[ -z "$_org" ]] && continue
                if ! check_ado_auth "$_org" &>/dev/null; then
                    pat_all_ok=false
                    break
                fi
            done <<< "$uorg"
            if [[ "$pat_all_ok" == "true" ]]; then
                echo "  [ok] PAT (valid)"
            else
                echo "  [--] PAT (invalid)"
            fi
        fi
        echo "  ADO repos: $ado_cnt"
    fi
    echo ""

    echo "Schedule:"
    local cron_schedule
    cron_schedule="$(get_cron_schedule)"
    if [[ -n "$cron_schedule" ]]; then
        echo "  $(describe_schedule "$cron_schedule")"
    else
        echo "  not scheduled"
    fi
}

# --- Usage ---

usage() {
    cat <<EOF
nightshift v${VERSION} — nightly code auditing

Usage:
  nightshift init       Interactive setup wizard
  nightshift run        Run a scan now (also used by cron)
  nightshift logs       View the latest log file
  nightshift logs DATE  View log for a specific date (YYYY-MM-DD)
  nightshift status     Show config and detected CLIs
  nightshift check-ado-auth ORG
                        Verify NIGHTSHIFT_ADO_PAT against Azure DevOps (projects API)
EOF
}

# --- Main ---

if [[ -z "${NIGHTSHIFT_SKIP_MAIN:-}" ]]; then
case "${1:-}" in
    init)   cmd_init ;;
    run)    shift; cmd_run "$@" ;;
    logs)   shift; cmd_logs "$@" ;;
    status) cmd_status ;;
    check-ado-auth) shift; check_ado_auth "${1-}" || exit 1 ;;
    -h|--help|help) usage ;;
    "")     usage ;;
    *)      echo "Unknown command: $1"; usage; exit 1 ;;
esac
fi
